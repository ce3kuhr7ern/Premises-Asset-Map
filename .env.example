# Neon PostgreSQL — copy the connection string from your Neon project dashboard
DATABASE_URL=

# Clerk — from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect paths (defaults — change if your routes differ)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Used to verify incoming Clerk webhook calls to /api/auth/provision
CLERK_WEBHOOK_SECRET=
