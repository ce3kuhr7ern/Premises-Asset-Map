# Neon PostgreSQL — copy the connection string from your Neon project dashboard
DATABASE_URL="postgresql://neondb_owner:npg_SUbHIqR7sk1l@ep-lucky-butterfly-abktqn24-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Clerk — from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk redirect paths (defaults — change if your routes differ)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Used to verify incoming Clerk webhook calls to /api/auth/provision
CLERK_WEBHOOK_SECRET=

# Vercel Blob — file storage for /documents
# Generate from Vercel dashboard → Storage → Blob → Create token
BLOB_READ_WRITE_TOKEN=

# Anthropic — used for AI document auto-categorisation in the upload modal
# Optional — without it, uploads still work but AI suggestions are silently disabled
# Generate from https://console.anthropic.com → API keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
